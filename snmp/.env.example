# Copy to .env (gitignored) or export variables before docker compose / setup container.
# Get an API key: https://app.datadoghq.com/organization-settings/api-keys
#
# Option A — file (local only):
#   cp .env.example .env
#   # edit .env and set DD_API_KEY
#
# Option B — environment (good for CI / setup container):
#   export DD_API_KEY='<your_datadog_api_key>'

DD_API_KEY=
DD_SITE=datadoghq.com

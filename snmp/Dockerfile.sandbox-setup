# Docker CLI image: runs `docker compose` against the host daemon (mounted socket).
# Used by compose.sandbox.yaml so you only run one container — no Python required.
#
# Build is normally triggered by:
#   docker compose -f compose.sandbox.yaml build

FROM docker:27-cli

COPY snmp/sandbox-entrypoint.sh /usr/local/bin/sandbox-entrypoint.sh
RUN chmod +x /usr/local/bin/sandbox-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/sandbox-entrypoint.sh"]
CMD ["up"]
